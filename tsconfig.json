{
  
  "compilerOptions": {
    "moduleResolution": "node", 
    "module": "commonjs",
    "target": "ES2020",
    "types": ["node", "@playwright/test"],
  
    "ignoreDeprecations": "6.0",
  

    
   
    "lib": ["ES2020"],
    
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": [
    "tests/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
